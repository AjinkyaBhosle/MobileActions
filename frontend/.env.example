# Copy this file to `.env` and fill in your real values.
# DO NOT commit `.env` to GitHub.
#
# In Expo, env vars prefixed with EXPO_PUBLIC_ are exposed to the JS bundle at build time.
# WARNING: Anything here is shipped inside your APK and can be extracted by reverse-engineering.
# For production, proxy OpenAI calls through your own backend instead of bundling the key.

EXPO_PUBLIC_OPENAI_API_KEY=sk-your-openai-key-here

# Firebase config (the apiKey here is a public client config, not a secret — but still keep out of git)
EXPO_PUBLIC_FIREBASE_API_KEY=AIza...your-firebase-web-api-key
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=vibe-4f8c6.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=vibe-4f8c6
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=vibe-4f8c6.firebasestorage.app
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=569533089062
EXPO_PUBLIC_FIREBASE_APP_ID=1:569533089062:web:4a9cf111b04236aaf96de7
